      "source": [
        "x = int(input(\"x:\"))\n",
        "opt = input(\"運算:∧(次方)√(根號)\")\n",
        "y = int(input(\"y:\"))\n",
        "\n",
        "if opt == \"∧\"\n",
        "  result = x ** y\n",
        "elif opt == \"√\"\n",
        "   if y == 0:\n",
        "     result = \"數學不能開0次方根\"\n",
        "   else:\n",
        "     result = x ** (1/y)\n",
        "else:\n",
        "   result =\"請輸入∧或√\"\n",
        "print(result)\n"
      ]
    }
  ]
